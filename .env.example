# Mindstrate Configuration
# Copy this file to .env and fill in the values.

# =============================================================
# LLM provider — supports OpenAI and any OpenAI-compatible API
# =============================================================
# Required for LLM-driven features (embedding, knowledge extraction,
# session compression, evolution). Without an API key, Mindstrate
# falls back to local hash-based embeddings + rule-based extraction:
# fully offline, lower quality but free.
OPENAI_API_KEY=

# Base URL for the LLM endpoint. Defaults to OpenAI's official API.
# Set this to point at any OpenAI-compatible provider:
#
#   Aliyun Tongyi (DashScope OpenAI-compatible mode):
#     OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#     MINDSTRATE_LLM_MODEL=qwen-max
#     MINDSTRATE_EMBEDDING_MODEL=text-embedding-v3
#
#   DeepSeek (cheap, code-focused):
#     OPENAI_BASE_URL=https://api.deepseek.com/v1
#     MINDSTRATE_LLM_MODEL=deepseek-chat
#     # Note: DeepSeek has no embedding model. Use a separate embedding endpoint
#     # via OPENAI_EMBEDDING_BASE_URL, or leave OPENAI_API_KEY empty for local hash.
#
#   Moonshot (long context):
#     OPENAI_BASE_URL=https://api.moonshot.cn/v1
#     MINDSTRATE_LLM_MODEL=moonshot-v1-8k
#
#   Local (Ollama / vLLM / LM Studio):
#     OPENAI_BASE_URL=http://127.0.0.1:11434/v1
#     OPENAI_API_KEY=ollama   # any non-empty placeholder
#     MINDSTRATE_LLM_MODEL=qwen2.5
#
# OPENAI_BASE_URL=

# Optional: separate base URL for embeddings (mixed-provider mode).
# Useful when you want, say, Aliyun for chat (cheap) but OpenAI for
# embeddings (high quality). Defaults to OPENAI_BASE_URL.
# OPENAI_EMBEDDING_BASE_URL=

# =============================================================
# Models (all optional — sensible defaults if unset)
# =============================================================
# Embedding model:
#   OpenAI:  text-embedding-3-small (default), text-embedding-3-large
#   Aliyun:  text-embedding-v3, text-embedding-v2
# MINDSTRATE_EMBEDDING_MODEL=text-embedding-3-small

# Chat / completion model (for LLM extraction, session compression, evolution):
#   OpenAI:   gpt-4o-mini (default), gpt-4o
#   Aliyun:   qwen-max, qwen-plus, qwen-turbo
#   DeepSeek: deepseek-chat, deepseek-reasoner
#   Moonshot: moonshot-v1-8k, moonshot-v1-32k
# MINDSTRATE_LLM_MODEL=gpt-4o-mini

# =============================================================
# Data storage
# =============================================================
# Directory for storing all Mindstrate data (SQLite DB + vector index)
# Default: ~/.mindstrate
# MINDSTRATE_DATA_DIR=

# Override SQLite database path
# MINDSTRATE_DB_PATH=

# Override vector store path
# MINDSTRATE_VECTOR_PATH=

# =============================================================
# Team Server (for centralized team knowledge sharing)
# =============================================================

# --- MCP Server side (client connecting to Team Server) ---
# Set this to enable team mode. MCP Server will forward all
# requests to the Team Server instead of using local storage.
# TEAM_SERVER_URL=http://192.168.1.100:3388
# TEAM_API_KEY=your-team-secret-key

# --- Team Server side (the centralized server) ---
# TEAM_PORT=3388
# TEAM_API_KEY=your-team-secret-key

# =============================================================
# Obsidian vault sync (optional, personal use)
# =============================================================
# When set, the MCP Server mirrors every add/update/delete into a
# markdown file inside the vault, so you can browse / edit knowledge
# in Obsidian (with full Graph View, backlinks, mobile, etc.).
#
# Layout: <vault>/<project>/<type>/<title>--<id8>.md
# Edits made directly in Obsidian are watched and pushed back to Mindstrate
# (only when OBSIDIAN_WATCH=true; otherwise sync is one-way Mindstrate->vault).
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian-vault
# OBSIDIAN_AUTO_SYNC=true     # default: true; set false to disable
# OBSIDIAN_WATCH=false        # default: false; set true to watch the vault for edits
