# Mindstrate Configuration
# Copy this file to .env and fill in the values. Local CLI commands load
# the project-root .env automatically. Do not commit .env.

# =============================================================
# LLM / Embedding provider — configured in the Web UI, not here
# =============================================================
# Per-project OpenAI-compatible provider settings (API key, base URL,
# LLM model, embedding model, embedding dim) live in SQLite and are
# managed at:
#
#   Settings → LLM Configs   (admin only, in team mode)
#
# Projects without a config fall back to the offline 256-dim hash
# embedder and skip LLM extraction.
#
# The previous OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_EMBEDDING_BASE_URL
# / MINDSTRATE_LLM_MODEL / MINDSTRATE_EMBEDDING_MODEL env vars are no
# longer read by any process.

# Project graph LLM calls are batched and queued to avoid provider throttling.
# Lower the batch size and raise the delay for strict TPS/TPM quotas such as
# DashScope AllocationQuota limits.
# MINDSTRATE_PROJECT_GRAPH_LLM_FACT_BATCH_SIZE=20
# MINDSTRATE_PROJECT_GRAPH_LLM_DELAY_MS=1500
# MINDSTRATE_PROJECT_GRAPH_LLM_TIMEOUT_MS=60000

# =============================================================
# Data storage
# =============================================================
# Directory for storing all Mindstrate data (SQLite DB + vector index)
# Default: ~/.mindstrate
# MINDSTRATE_DATA_DIR=

# Locale for human-facing generated content such as project graph reports.
# Defaults to the operating system locale. Set to zh-CN for Simplified Chinese.
# MINDSTRATE_LOCALE=zh-CN

# Override SQLite database path
# MINDSTRATE_DB_PATH=

# Vector store backend: "local" (default, JSON file) or "qdrant".
# MINDSTRATE_VECTOR_BACKEND=local
# MINDSTRATE_QDRANT_URL=http://127.0.0.1:6333

# Override local vector store path
# MINDSTRATE_VECTOR_PATH=

# --- Search performance tuning (optional) ---
# Max node embeddings pulled into memory for one similarity scan (SQLite
# backend). Raise on big-memory hosts, lower to cap peak RSS. Default 5000.
# MINDSTRATE_VECTOR_CANDIDATE_LIMIT=5000
# Per-request timeout (ms) for embedding the search query. On timeout the
# search falls back to lexical-only instead of stalling. 0 disables. Default 3000.
# MINDSTRATE_EMBED_TIMEOUT_MS=3000
# TTL (ms) for the knowledge-projection cache reused across back-to-back
# searches. Same-process writes always invalidate it. 0 disables. Default 5000.
# MINDSTRATE_PROJECTION_CACHE_TTL_MS=5000

# =============================================================
# Team Server (for centralized team knowledge sharing)
# =============================================================

# --- MCP Server side (client connecting to Team Server) ---
# Set this to enable team mode. MCP Server will forward all
# requests to the Team Server instead of using local storage.
# TEAM_SERVER_URL=http://192.168.1.100:3388
# TEAM_API_KEY=<your member key, minted by the admin in Settings → Users>
# HTTP request timeout (ms) for team-mode calls. Raise on slow embedding
# providers / very large graphs where /api/graph/search runs long. Default 30000.
# TEAM_HTTP_TIMEOUT_MS=30000

# --- Team Server side (the centralized server) ---
# TEAM_PORT=3388
# TEAM_API_KEY=<admin bootstrap key; mint per-member keys via Web UI>

# =============================================================
# Obsidian vault sync (optional, personal use)
# =============================================================
# When set, the MCP Server mirrors every add/update/delete into a
# markdown file inside the vault, so you can browse / edit knowledge
# in Obsidian (with full Graph View, backlinks, mobile, etc.).
#
# Layout: <vault>/<project>/<type>/<title>--<id8>.md
# Edits made directly in Obsidian are watched and pushed back to Mindstrate
# (only when OBSIDIAN_WATCH=true; otherwise sync is one-way Mindstrate->vault).
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian-vault
# OBSIDIAN_AUTO_SYNC=true     # default: true; set false to disable
# OBSIDIAN_WATCH=false        # default: false; set true to watch the vault for edits
