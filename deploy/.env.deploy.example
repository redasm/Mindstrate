# Mindstrate deployment configuration
# Copy this file to `.env.deploy` (next to docker-compose.deploy.yml)
# and fill in the values.

# -----------------------------------------------------------------
# REQUIRED — Team Server admin bootstrap key
# -----------------------------------------------------------------
# Any string the admin sends as Bearer token. Generate with:
#   openssl rand -hex 32
#
# Role: this single key acts as the admin bootstrap. The admin signs
# in to the Web UI at /admin/api-keys with this value and mints
# per-member, project-scoped keys from there. Member keys live in
# the shared SQLite DB and never need to be in .env.
TEAM_API_KEY=

# -----------------------------------------------------------------
# Ports (host side). Change if these clash with existing services.
# Inside the containers the ports are always 3388 and 3377.
# -----------------------------------------------------------------
TEAM_PORT=3388
WEB_UI_PORT=3377

# Bind addresses. Default 0.0.0.0 = reachable on every interface.
# Set to 127.0.0.1 if you want to expose the service only via a
# reverse proxy on the host.
TEAM_BIND=0.0.0.0
WEB_UI_BIND=0.0.0.0

# -----------------------------------------------------------------
# Optional — LLM provider (any OpenAI-compatible API works)
# -----------------------------------------------------------------
# Without OPENAI_API_KEY the server falls back to local hash-based
# embeddings + rule-based extraction (lower quality but fully offline).
OPENAI_API_KEY=

# Base URL — leave empty for OpenAI official, or pick a compatible provider:
#   Aliyun:   https://dashscope.aliyuncs.com/compatible-mode/v1
#   DeepSeek: https://api.deepseek.com/v1
#   Moonshot: https://api.moonshot.cn/v1
#   Local:    http://host.docker.internal:11434/v1   (Ollama on host)
# OPENAI_BASE_URL=

# Optional separate base URL for embeddings (mixed-provider mode).
# OPENAI_EMBEDDING_BASE_URL=

# Models — defaults: text-embedding-3-small / gpt-4o-mini
# Aliyun example:   EMBEDDING_MODEL=text-embedding-v3, LLM_MODEL=qwen-max
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------
# Optional — repo-scanner daemon (enable with `--profile scanner`)
# -----------------------------------------------------------------
# Set INSTALL_P4=1 if you need to scan Perforce depots (bakes the
# Helix CLI into the image, ~50 MB). Leave as 0 for Git-only.
INSTALL_P4=0
# Per-source connection details (Git remote URL + token, or P4
# host/user/password) are configured from the admin Web UI at
#   http://<host>:${WEB_UI_PORT}/admin/scanner-sources
# and stored in the shared mindstrate-data SQLite, so one scanner
# container can serve many projects with different servers/accounts.

# -----------------------------------------------------------------
# Misc
# -----------------------------------------------------------------
LOG_LEVEL=info
MINDSTRATE_LOCALE=zh-CN   # generated project graph/report language
WEB_UI_LOCALE=zh        # zh | en
