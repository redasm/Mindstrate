# Mindstrate deployment configuration
# Copy this file to `.env.deploy` (next to docker-compose.deploy.yml)
# and fill in the values.

# -----------------------------------------------------------------
# REQUIRED — Team Server admin bootstrap key
# -----------------------------------------------------------------
# Any string the admin sends as Bearer token. Generate with:
#   openssl rand -hex 32
#
# Role: this single key acts as the admin bootstrap. The admin signs
# in to the Web UI at /admin/api-keys with this value and mints
# per-member, project-scoped keys from there. Member keys live in
# the shared SQLite DB and never need to be in .env.
TEAM_API_KEY=

# -----------------------------------------------------------------
# Ports (host side). Change if these clash with existing services.
# Inside the containers the ports are always 3388 and 3377.
# -----------------------------------------------------------------
TEAM_PORT=3388
WEB_UI_PORT=3377

# Bind addresses. Default 0.0.0.0 = reachable on every interface.
# Set to 127.0.0.1 if you want to expose the service only via a
# reverse proxy on the host.
TEAM_BIND=0.0.0.0
WEB_UI_BIND=0.0.0.0

# -----------------------------------------------------------------
# LLM provider config — moved to the Web UI
# -----------------------------------------------------------------
# Per-project OpenAI / DashScope / DeepSeek / Moonshot / Ollama
# settings are now configured at:
#   Settings → LLM Configs   (admin-only)
# Projects without a config fall back to the offline 256-dim hash
# embedder and skip LLM extraction.
#
# (Previous OPENAI_API_KEY / OPENAI_BASE_URL / EMBEDDING_MODEL /
# LLM_MODEL env vars are no longer read.)

# -----------------------------------------------------------------
# Misc
# -----------------------------------------------------------------
LOG_LEVEL=info
MINDSTRATE_LOCALE=zh-CN   # generated project graph/report language
WEB_UI_LOCALE=zh        # zh | en
