# Mindstrate deployment configuration
# Copy this file to `.env.deploy` (next to docker-compose.deploy.yml)
# and fill in the values.

# -----------------------------------------------------------------
# REQUIRED — Team Server admin bootstrap key
# -----------------------------------------------------------------
# Any string the admin sends as Bearer token. Generate with:
#   openssl rand -hex 32
#
# Role: this single key acts as the admin bootstrap. The admin signs
# in to the Web UI at /admin/api-keys with this value and mints
# per-member, project-scoped keys from there. Member keys live in
# the shared SQLite DB and never need to be in .env.
TEAM_API_KEY=

# -----------------------------------------------------------------
# Ports (host side). Change if these clash with existing services.
# Inside the containers the ports are always 3388 and 3377.
# -----------------------------------------------------------------
TEAM_PORT=3388
WEB_UI_PORT=3377

# Bind addresses. Default 0.0.0.0 = reachable on every interface.
# Set to 127.0.0.1 if you want to expose the service only via a
# reverse proxy on the host.
TEAM_BIND=0.0.0.0
WEB_UI_BIND=0.0.0.0

# -----------------------------------------------------------------
# LLM provider config — moved to the Web UI
# -----------------------------------------------------------------
# Per-project OpenAI / DashScope / DeepSeek / Moonshot / Ollama
# settings are now configured at:
#   Settings → LLM Configs   (admin-only)
# Projects without a config fall back to the offline 256-dim hash
# embedder and skip LLM extraction.
#
# (Previous OPENAI_API_KEY / OPENAI_BASE_URL / EMBEDDING_MODEL /
# LLM_MODEL env vars are no longer read.)

# -----------------------------------------------------------------
# Repo scanner (only used with `--profile scanner`)
# -----------------------------------------------------------------
# Bake the Perforce CLI into the repo-scanner image (~50 MB). REQUIRED when any
# scanner source is a P4 depot — otherwise the scan logs
#   "p4: not found ... cursor not set — will retry on the next scan"
# and no P4 changelists are ever ingested. Set to 1 for P4 teams.
# Build args are baked at image build time — re-run with `--no-cache` after
# changing this:
#   docker compose -f deploy/docker-compose.deploy.yml --env-file deploy/.env.deploy \
#     --profile scanner build --no-cache repo-scanner
INSTALL_P4=0

# -----------------------------------------------------------------
# Misc
# -----------------------------------------------------------------
LOG_LEVEL=info
MINDSTRATE_LOCALE=zh-CN   # generated project graph/report language
WEB_UI_LOCALE=zh        # zh | en

# -----------------------------------------------------------------
# Background metabolism scheduler (team-server)
# -----------------------------------------------------------------
# The team-server is the only process that runs ECS metabolism on a timer.
# Leave enabled so knowledge is automatically digested/assimilated/compressed/
# reflected/pruned. Set to "false" to require manual `mindstrate gc` instead.
MINDSTRATE_METABOLISM_SCHEDULER=true
MINDSTRATE_METABOLISM_INTERVAL_MS=300000   # run interval in ms (default 5 min)
# MINDSTRATE_METABOLISM_PROJECT=            # empty = all projects

# Skill-evolution optimizer (runs on the metabolism scheduler cadence).
# Off by default: it runs an LLM proposer per low-adoption / negatively-rated
# high-order skill node and produces CANDIDATE patches for human review in the
# Web UI (nothing is auto-applied). Enable once feedback has accumulated.
MINDSTRATE_SKILL_EVOLUTION_SCHEDULER=false
MINDSTRATE_SKILL_EVOLUTION_EVERY_TICKS=12  # run every Nth metabolism tick

# Auto-generate the retrieval eval dataset from accumulated knowledge on the
# scheduler cadence (self-retrieval probes: query = knowledge title, expected =
# that knowledge's id). Idempotent — only newly-covered knowledge adds cases.
# Off by default; enable once a project has knowledge worth measuring.
MINDSTRATE_EVAL_DATASET_SCHEDULER=false
MINDSTRATE_EVAL_DATASET_EVERY_TICKS=12     # run every Nth metabolism tick
