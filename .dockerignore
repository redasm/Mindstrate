# Files NOT to send into the docker build context.
# Keeps the build fast and prevents leaking local state into images.

# Build outputs
**/dist/
**/.next/
**/.turbo/
**/tsconfig.tsbuildinfo

# Local node_modules (each Dockerfile re-installs from package-lock)
**/node_modules/

# Local data, secrets, scratch
.env
.env.*
!deploy/.env.deploy.example
.mindstrate/
test-data/
backups/
*.log
*.db
*.db-journal
*.db-wal
*.db-shm

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Git (we don't need history at build-time)
.git/
.github/
