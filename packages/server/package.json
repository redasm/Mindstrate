{
  "name": "@mindstrate/server",
  "version": "0.1.0",
  "description": "Server-side runtime for Mindstrate: storage, embedding, retrieval, quality engine, project detection. Used by team-server, cli, web-ui and obsidian-sync.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-project-rules.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@mindstrate/client": "*",
    "@mindstrate/protocol": "*",
    "better-sqlite3": "^11.7.0",
    "openai": "^4.77.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
